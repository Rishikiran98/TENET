# Copy to .env and adjust. Loaded by src/hieromem/config.py (pydantic-settings).

# Store backend: "memory" (zero infra, default) or "postgres" (pgvector).
STORE_BACKEND=memory

# Embedder backend: "hash" (deterministic, zero deps) or "sentence-transformer".
EMBEDDER_BACKEND=hash

# Embedding dimensionality. Must match the vector(...) column when using postgres.
EMBEDDING_DIM=384

# Connection string for the postgres backend (ignored when STORE_BACKEND=memory).
DATABASE_URL=postgresql://hieromem:hieromem@localhost:5432/hieromem
